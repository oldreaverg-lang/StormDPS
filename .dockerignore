# NOTE: compile_cache.py is NEEDED AT RUNTIME — core.dps_engine imports
# detect_landfall_events, apply_basin_dps_adjustment, COASTAL_REGIONS, etc.
# from it. Do NOT add it here (the /storms/{id}/dps endpoint will 500 with
# "No module named 'compile_cache'" if it's excluded from the image).
build_preload.py

# Docs (not needed at runtime)
*.md
*.docx
*.webp

# Cache data (rebuilt at runtime)
data/cache/
data/validation/

# Mobile app source (separate deployment)
mobile/

# Environment files
.env
.env.example
