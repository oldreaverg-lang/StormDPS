# Version control
.git
.gitignore

# Python
__pycache__
*.pyc
*.pyo
venv/
.venv/
env/
*.egg-info/

# Virtual environment
venv/

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Development/debug scripts
analyze_*.py
compare_*.py
debug_*.py
