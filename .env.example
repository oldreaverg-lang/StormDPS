# Hurricane DPI API — Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================
# REQUIRED: None — the app works with free APIs by default
# ============================================================

# ============================================================
# OPTIONAL: Google Maps Platform Weather API
# Provides: current conditions, hourly/daily forecasts, weather alerts, SST
# Get your key: https://console.cloud.google.com/google/maps-apis
# Pricing: $0.005/request (first $200/month free)
# ============================================================
GOOGLE_MAPS_API_KEY=

# ============================================================
# OPTIONAL: Google Cloud / WeatherNext 2 (AI Cyclone Predictions)
# Provides: 15-day track/intensity forecasts with 50 ensemble members
# Requires: Google Cloud project with Vertex AI enabled
# Access: Early Access Program — https://developers.google.com/weathernext
# ============================================================
GOOGLE_CLOUD_PROJECT=
WEATHERNEXT_API_KEY=
# Or use service account credentials:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================
# FREE APIs (no key required, configured automatically)
# ============================================================
# NWS API (api.weather.gov) — US hurricane forecasts, alerts, gridded data
# Open-Meteo — Global weather, soil moisture, SST, wind shear, flood forecasts
# NOAA/NHC — Active storms, IBTrACS, HURDAT2, GFS wind fields

# ============================================================
# APP CONFIGURATION
# ============================================================
# Server host and port
HOST=0.0.0.0
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Cache settings
IKE_CACHE_DIR=data/cache/ike
IBTRACS_CACHE_TTL_HOURS=6

# Preload settings (compute IKE for preset storms on startup)
PRELOAD_ON_STARTUP=true
PRELOAD_GRID_RESOLUTION_KM=15

# ============================================================
# SECURITY
# ============================================================
# Admin token — required for all destructive/admin endpoints
# (DELETE /cache/*, POST /preload/generate, POST /validation/outcome,
# POST /audit/radii/*, POST /admin/warm-ibtracs).
# Pass as the X-Admin-Token header. If unset, those endpoints return 503.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# Comma-separated list of allowed CORS origins.
# REQUIRED in production — defaults to localhost-only if unset.
# Example: ALLOWED_ORIGINS=https://stormdps.app,https://www.stormdps.app
ALLOWED_ORIGINS=

# Set to "true" to expose /docs, /redoc, /openapi.json (default: disabled).
# Leave unset in production — the docs enumerate every endpoint.
ENABLE_API_DOCS=false

# Global per-IP rate limit (slowapi syntax: "<count>/<period>")
# Examples: 300/minute, 5/second, 1000/hour
RATE_LIMIT_DEFAULT=300/minute
